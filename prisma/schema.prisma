generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?
  cases       Case[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Case {
  id                Int       @id @default(autoincrement())
  slug              String    @unique
  title             String
  summary           String?
  procurementNumber String?
  region            String?
  subject           String?
  violation         String?
  applicantPosition String?
  decision          String?
  result            String?
  pdfUrl            String?
  customerName      String?
  customerInn       String?
  customerKpp       String?
  decisionDate      DateTime?
  isFeatured        Boolean   @default(false)
  published         Boolean   @default(true)
  categoryId        Int?
  category          Category? @relation(fields: [categoryId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([region])
  @@index([violation])
  @@index([result])
  @@index([published])
  @@index([isFeatured])
  @@index([customerName])
  @@index([customerInn])
  @@index([customerKpp])
  @@index([decisionDate])
}

model Service {
  id               Int      @id @default(autoincrement())
  title            String
  slug             String   @unique
  shortDescription String?
  content          String?
  published        Boolean  @default(true)
  seoTitle         String?
  seoDescription   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Page {
  id             Int      @id @default(autoincrement())
  title          String
  slug           String   @unique
  content        String?
  published      Boolean  @default(true)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Lead {
  id              Int      @id @default(autoincrement())
  procurementLink String?
  problem         String?
  phone           String?
  email           String?
  status          String   @default("new")
  comment         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Admin {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String?
  passwordHash String
  role         TenderUserRole @default(ADMIN)
  comments     TenderStageComment[]
  chatThreads  TenderChatThread[]
  chatMessages TenderChatMessage[]
  promptConfigs TenderPromptConfig[]
  vpnProfile   TenderVpnProfile?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum TenderChatThreadKind {
  GENERAL
}

enum TenderChatMessageRole {
  USER
  ASSISTANT
}

model TenderChatThread {
  id        Int                  @id @default(autoincrement())
  ownerId   Int
  title     String               @default("Личный чат")
  kind      TenderChatThreadKind @default(GENERAL)
  owner     Admin                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  messages  TenderChatMessage[]
  attachments TenderChatAttachment[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([ownerId])
}

model TenderChatMessage {
  id         Int                   @id @default(autoincrement())
  threadId    Int
  role       TenderChatMessageRole
  body       String                @db.Text
  authorId   Int?
  authorName String?
  thread     TenderChatThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author     Admin?                @relation(fields: [authorId], references: [id], onDelete: SetNull)
  attachments TenderChatAttachment[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([threadId, createdAt])
  @@index([authorId])
}

model TenderChatAttachment {
  id             Int               @id @default(autoincrement())
  threadId       Int
  messageId      Int?
  title          String
  fileName       String
  mimeType       String?
  fileSize       Int?
  storagePath    String?
  documentKind   String?
  extractionNote String?
  extractedText  String?           @db.Text
  summaryText    String?           @db.Text
  thread         TenderChatThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  message        TenderChatMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([threadId, createdAt])
  @@index([messageId])
}

model TenderVpnProfile {
  id             Int      @id @default(autoincrement())
  adminId        Int      @unique
  label          String
  endpoint       String
  clientAddress  String   @unique
  clientPublicKey String
  serverPublicKey String
  configText     String   @db.Text
  isActive       Boolean  @default(true)
  admin          Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum TenderUserRole {
  ADMIN
  OPERATOR
  ANALYST
  MANAGER
  SUBMITTER
  FAS_SPECIALIST
  FAS_MANAGER
}

enum TenderFasReviewStatus {
  NOT_STARTED
  NO_VIOLATION
  POTENTIAL_COMPLAINT
  MANUAL_REVIEW
}

enum TenderPromptConfigKey {
  FAS_POTENTIAL_COMPLAINT
}

enum MaterialType {
  ANALYTICS
  FAS_PRACTICE
  VIOLATIONS
  CONTROVERSIAL
  NONPAYMENT
  RNP
  CUSTOMERS
  COMPLAINT
  COURT
}

model Material {
  id             Int          @id @default(autoincrement())
  title          String
  slug           String       @unique
  type           MaterialType @default(ANALYTICS)
  topic          String?
  authority      String?
  outcome        String?
  caseNumber     String?
  decisionDate   DateTime?
  excerpt        String?
  body           String       @db.Text
  seoTitle       String?
  seoDescription String?
  pdfUrl         String?
  sourceName     String?
  isPublished    Boolean      @default(false)
  isFeatured     Boolean      @default(false)
  sortOrder      Int          @default(0)
  publishedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([type])
  @@index([topic])
  @@index([authority])
  @@index([outcome])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([decisionDate])
  @@index([publishedAt])
  @@index([updatedAt])
  @@index([createdAt])
}

enum TenderProcurementStatus {
  NEW
  ANALYSIS
  STOPPED
  PRICING
  APPROVED
  IN_PREPARATION
  READY
  SUBMITTED
  ARCHIVED
}

enum TenderRuleKind {
  CUSTOMER
  PROCUREMENT
  CATEGORY
  BRAND
  MANUFACTURER
  REGULATORY
  DELIVERY
  OTHER
}

enum TenderDecision {
  SUBMIT
  DECLINE
  FAS_COMPLAINT
  REWORK
}

enum TenderCompanyDocumentType {
  COMPANY_CARD
  CHARTER
  TIN_CERTIFICATE
  OGRN_CERTIFICATE
  DIRECTOR_APPOINTMENT
  EGRUL_EXTRACT
  POWER_OF_ATTORNEY
  BANK_DETAILS
  DECLARATION
  OTHER
}

enum TenderTechnicalItemStatus {
  EXPLICIT
  IDENTIFIED
  REVIEW
  REJECTED
}

enum TenderActionType {
  CREATED
  STATUS_UPDATED
  AI_ANALYZED
  STOP_FACTORS_REVIEWED
  PRICING_UPDATED
  DECISION_MADE
  DOCUMENTS_PREPARED
  SUBMITTED
  NOTE_ADDED
}

enum TenderProcurementDocumentStatus {
  REQUIRED
  READY
  MISSING
  REVIEW
}

enum TenderSourceDocumentStatus {
  UPLOADED
  WAIT_DECISION
  READY_FOR_ANALYSIS
  ANALYZED
}

enum TenderSourceDocumentFormType {
  UNKNOWN
  APPLICATION_FORM
  PRICE_FORM
  TECHNICAL_PROPOSAL
  QUESTIONNAIRE
  DECLARATION
  CONTRACT_DRAFT
  TECHNICAL_SPEC
  OTHER_APPENDIX
}

enum TenderSourceDocumentAutofillStatus {
  NOT_ANALYZED
  PARTIALLY_READY
  MANUAL_ONLY
  READY_TO_FILL
}

model TenderCompanyProfile {
  id                    Int                     @id @default(autoincrement())
  name                  String
  legalName             String?
  inn                   String?                 @unique
  kpp                   String?
  ogrn                  String?
  registrationDate      DateTime?
  directorName          String?
  email                 String?
  phone                 String?
  legalAddress          String?
  postalAddress         String?
  okpo                  String?
  oktmo                 String?
  activityCode          String?
  activityDescription   String?
  bankName              String?
  bankBik               String?
  bankAccount           String?
  correspondentAccount  String?
  notes                 String?
  isPrimary             Boolean                 @default(false)
  documents             TenderCompanyDocument[]
  procurements          TenderProcurement[]
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  tenderDecisionRecords TenderDecisionRecord[]
}

model TenderCompanyDocument {
  id           Int                       @id @default(autoincrement())
  companyId    Int
  title        String
  documentType TenderCompanyDocumentType @default(OTHER)
  fileName     String?
  storagePath  String?
  notes        String?
  company      TenderCompanyProfile      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  procurementDocuments TenderProcurementDocument[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@index([companyId])
  @@index([documentType])
}

model TenderStopRule {
  id                   Int                          @id @default(autoincrement())
  code                 String                       @unique
  name                 String
  description          String?
  kind                 TenderRuleKind               @default(OTHER)
  sortOrder            Int                          @default(0)
  isActive             Boolean                      @default(true)
  isToggleable         Boolean                      @default(true)
  requiresManualReview Boolean                      @default(false)
  customerInn          String?
  manufacturerName     String?
  brandName            String?
  keyword              String?
  thresholdPercent     Int?
  matches              TenderProcurementRuleMatch[]
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  @@index([kind])
  @@index([isActive])
  @@index([sortOrder])
}

model TenderInnRegistry {
  id          Int      @id @default(autoincrement())
  inn         String   @unique
  label       String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([inn])
  @@index([isActive])
}

model TenderProcurement {
  id                       Int                          @id @default(autoincrement())
  title                    String
  sourceUrl                String?
  sourceText               String?                      @db.Text
  customerName             String?
  customerInn              String?
  procurementNumber        String?
  platform                 String?
  status                   TenderProcurementStatus      @default(NEW)
  deadline                 DateTime?
  nmck                     Decimal?                     @db.Decimal(15, 2)
  nmckWithoutVat           Decimal?                     @db.Decimal(15, 2)
  itemsCount               Int?
  purchaseType             String?
  summary                  String?
  selectionCriteria        String?
  requiredDocuments        Json?
  nonstandardRequirements  Json?
  deliveryTerms            String?
  paymentTerms             String?
  contractTerm             String?
  penaltyTerms             String?
  terminationTerms         Json?
  regulatoryRequirements   Json?
  requiresCommissioning    Boolean                      @default(false)
  analogsAllowed           Boolean?
  stopFactorsSummary       String?
  aiAnalysis               Json?
  aiAnalysisStatus         String?
  aiAnalysisError          String?                      @db.Text
  aiAnalyzedAt             DateTime?
  aiModel                  String?
  approximatePurchasePrice Decimal?                     @db.Decimal(15, 2)
  pricingComment           String?                      @db.Text
  pricingStatus            String?
  pricingReviewedAt        DateTime?
  approvedBidAmount        Decimal?                     @db.Decimal(15, 2)
  decision                 TenderDecision?
  decisionComment          String?                      @db.Text
  decisionMadeAt           DateTime?
  estimatedCost            Decimal?                     @db.Decimal(15, 2)
  bidPrice                 Decimal?                     @db.Decimal(15, 2)
  isProfitable             Boolean?
  assignedTo               String?
  companyProfileId         Int?
  companyProfile           TenderCompanyProfile?        @relation(fields: [companyProfileId], references: [id])
  technicalItems           TenderTechnicalItem[]
  pricingReviews           TenderPricingReview[]
  decisions                TenderDecisionRecord[]
  procurementDocuments     TenderProcurementDocument[]
  sourceDocuments          TenderSourceDocument[]
  stageComments            TenderStageComment[]
  fasReview                TenderFasReview?
  events                   TenderProcurementEvent[]
  ruleMatches              TenderProcurementRuleMatch[]
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt

  @@index([status])
  @@index([deadline])
  @@index([customerInn])
  @@index([companyProfileId])
}

model TenderPromptConfig {
  id          Int                   @id @default(autoincrement())
  key         TenderPromptConfigKey @unique
  title       String
  body        String                @db.Text
  updatedById Int?
  updatedBy   Admin?                @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model TenderFasReview {
  id             Int                   @id @default(autoincrement())
  procurementId  Int                   @unique
  status         TenderFasReviewStatus @default(NOT_STARTED)
  findingTitle   String?
  findingBasis   String?               @db.Text
  confidenceNote String?               @db.Text
  promptSnapshot String?               @db.Text
  assignedTo     String?
  reviewComment  String?               @db.Text
  lastAnalyzedAt DateTime?
  procurement    TenderProcurement     @relation(fields: [procurementId], references: [id], onDelete: Cascade)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model TenderStageComment {
  id            Int               @id @default(autoincrement())
  procurementId Int
  stageKey      String
  stageTitle    String?
  body          String            @db.Text
  authorId      Int?
  authorName    String?
  authorRole    TenderUserRole?
  procurement   TenderProcurement @relation(fields: [procurementId], references: [id], onDelete: Cascade)
  author        Admin?            @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([procurementId, stageKey])
  @@index([authorId])
  @@index([createdAt])
}

model TenderTechnicalItem {
  id                   Int                       @id @default(autoincrement())
  procurementId        Int
  lineNumber           Int?
  requestedName        String
  quantity             String?
  unit                 String?
  rawCharacteristics   String?                   @db.Text
  identifiedProduct    String?
  identifiedBrand      String?
  identifiedModel      String?
  identificationBasis  String?                   @db.Text
  approximateUnitPrice Decimal?                  @db.Decimal(15, 2)
  sourceSummary        String?                   @db.Text
  sourceLinks          Json?
  status               TenderTechnicalItemStatus @default(REVIEW)
  confidence           Int?
  reviewQuestion       String?                   @db.Text
  pricingReady         Boolean                   @default(false)
  procurement          TenderProcurement         @relation(fields: [procurementId], references: [id], onDelete: Cascade)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@index([procurementId])
  @@index([status])
}

model TenderPricingReview {
  id                       Int               @id @default(autoincrement())
  procurementId            Int
  approximatePurchasePrice Decimal?          @db.Decimal(15, 2)
  pricingStatus            String?
  sourceSummary            String?           @db.Text
  sourceLinks              Json?
  aiComment                String?           @db.Text
  createdBy                String?
  procurement              TenderProcurement @relation(fields: [procurementId], references: [id], onDelete: Cascade)
  createdAt                DateTime          @default(now())

  @@index([procurementId])
  @@index([createdAt])
}

model TenderDecisionRecord {
  id                Int                   @id @default(autoincrement())
  procurementId     Int
  companyProfileId  Int?
  decision          TenderDecision
  approvedBidAmount Decimal?              @db.Decimal(15, 2)
  comment           String?               @db.Text
  decidedBy         String?
  companyProfile    TenderCompanyProfile? @relation(fields: [companyProfileId], references: [id])
  procurement       TenderProcurement     @relation(fields: [procurementId], references: [id], onDelete: Cascade)
  createdAt         DateTime              @default(now())

  @@index([procurementId])
  @@index([companyProfileId])
  @@index([createdAt])
}

model TenderProcurementDocument {
  id                 Int                           @id @default(autoincrement())
  procurementId      Int
  companyDocumentId  Int?
  title              String
  category           String?
  fileName           String?
  note               String?                       @db.Text
  status             TenderProcurementDocumentStatus @default(REQUIRED)
  procurement        TenderProcurement             @relation(fields: [procurementId], references: [id], onDelete: Cascade)
  companyDocument    TenderCompanyDocument?        @relation(fields: [companyDocumentId], references: [id], onDelete: SetNull)
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  @@index([procurementId])
  @@index([companyDocumentId])
  @@index([status])
}

model TenderSourceDocument {
  id               Int                              @id @default(autoincrement())
  procurementId    Int
  title            String
  fileName         String?
  documentKind     String?
  contentSnippet   String?                          @db.Text
  status           TenderSourceDocumentStatus       @default(UPLOADED)
  formType         TenderSourceDocumentFormType     @default(UNKNOWN)
  autofillStatus   TenderSourceDocumentAutofillStatus @default(NOT_ANALYZED)
  extractedSummary String?                          @db.Text
  extractedFields  Json?
  structuredFields Json?
  draftContent     String?                          @db.Text
  reviewQuestion   String?                          @db.Text
  note             String?                          @db.Text
  procurement      TenderProcurement                @relation(fields: [procurementId], references: [id], onDelete: Cascade)
  createdAt        DateTime                         @default(now())
  updatedAt        DateTime                         @updatedAt

  @@index([procurementId])
  @@index([status])
  @@index([formType])
}

model TenderProcurementEvent {
  id            Int               @id @default(autoincrement())
  procurementId Int
  actionType    TenderActionType
  title         String
  description   String?           @db.Text
  actorName     String?
  metadata      Json?
  procurement   TenderProcurement @relation(fields: [procurementId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())

  @@index([procurementId])
  @@index([actionType])
  @@index([createdAt])
}

model TenderProcurementRuleMatch {
  id            Int               @id @default(autoincrement())
  procurementId Int
  ruleId        Int
  matchedValue  String?
  confidence    Float?
  isConfirmed   Boolean           @default(false)
  createdAt     DateTime          @default(now())
  procurement   TenderProcurement @relation(fields: [procurementId], references: [id], onDelete: Cascade)
  rule          TenderStopRule    @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([procurementId, ruleId])
  @@index([ruleId])
}
